{
  "manifest_version": 3,
  "name": "SmartBlocker FMP",
  "version": "0.1",
  "description": "Heuristic Ad-Blocking Engine Prototype",
  "permissions": ["sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Open SmartBlocker"
  }
}
